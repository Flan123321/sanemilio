RewriteEngine On

# 1. Redirect external requests for /page.html to /page (except for actual files/directories)
RewriteCond %{THE_REQUEST} \s/+(.*?)\.html\s [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# 2. Internally rewrite /page to /page.html if the file exists
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^ %{REQUEST_URI}.html [L]
